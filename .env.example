# ---------------------------------------------------------
# MM2 Shop Discovery Tool – Environment Configuration
# ---------------------------------------------------------
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------

# Serper.dev API keys (comma-separated for auto-rotation)
SERPER_API_KEYS=key1,key2,key3

# Scraper settings
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_CONCURRENCY=5

# Optional: rotating proxy URL (SOCKS5 or HTTP)
# PROXY_URL=socks5://user:pass@proxy-host:1080

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
